[submodule "kernel/libcxxrt"]
	path = kernel/libcxxrt
	url = https://github.com/libcxxrt/libcxxrt
[submodule "llvm-project"]
	path = llvm-project
	url = https://github.com/llvm/llvm-project.git
	branch = release/16.x
[submodule "userspace/terminald/flanterm"]
	path = userspace/terminald/flanterm
	url = https://codeberg.org/Mintsuki/Flanterm.git
[submodule "userspace/devicesd/uACPI"]
	path = userspace/devicesd/uACPI
	url = https://github.com/uACPI/uACPI.git
[submodule "limine/Hyper"]
	path = limine/Hyper
	url = https://github.com/UltraOS/Hyper.git
[submodule "kernel/uACPI"]
	path = kernel/uACPI
	url = https://github.com/uACPI/uACPI.git
[submodule "limine/limine"]
	path = limine/limine
	url = https://codeberg.org/Limine/Limine.git
	branch = v10.x-binary
